# ============================================================
# .env.example  –  Copy this file to ".env" and fill in values.
# NEVER commit .env to version control.
# ============================================================

# --- PostgreSQL (used by docker-compose and Python scripts) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=datawarehouse
POSTGRES_USER=dw_user
POSTGRES_PASSWORD=dw_password

# --- Kaggle API credentials (required for kagglehub downloads) ---
# Get these from https://www.kaggle.com/account → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# --- Data paths (absolute paths recommended on Windows) ---
# Root directory where downloaded datasets will be stored
DATA_ROOT=./data
